{
  "assumptions": [],
  "block_id": "oracle_basic_001_functional_001",
  "code_lines": [
    "inputs = env.get_case_inputs(plan_case_id)",
    "a = inputs['a']",
    "b = inputs['b']",
    "aluc = inputs['aluc']",
    "outputs = await env.sample_outputs(observed_signals)",
    "r = outputs['r']",
    "zero = outputs['zero']",
    "carry = outputs['carry']",
    "negative = outputs['negative']",
    "overflow = outputs['overflow']",
    "flag = outputs['flag']",
    "mask32 = mask_width(32)",
    "# opcode constants",
    "ADD   = 0b100000",
    "ADDU  = 0b100001",
    "SUB   = 0b100010",
    "SUBU  = 0b100011",
    "AND   = 0b100100",
    "OR    = 0b100101",
    "XOR   = 0b100110",
    "NOR   = 0b100111",
    "SLT   = 0b101010",
    "SLTU  = 0b101011",
    "SLL   = 0b000000",
    "SRL   = 0b000010",
    "SRA   = 0b000011",
    "SLLV  = 0b000100",
    "SRLV  = 0b000110",
    "SRAV  = 0b000111",
    "LUI   = 0b001111",
    "# default expected values (high\u2011impedance case)",
    "expected_r = None",
    "expected_carry = None",
    "expected_overflow = None",
    "expected_flag = 0",
    "if aluc == ADD:",
    "    sum_ = to_uint(a, 32) + to_uint(b, 32)",
    "    expected_carry = (sum_ >> 32) & 1",
    "    expected_r = sum_ & mask32",
    "    sa = to_sint(a, 32)",
    "    sb = to_sint(b, 32)",
    "    sr = to_sint(expected_r, 32)",
    "    expected_overflow = int((sa > 0 and sb > 0 and sr < 0) or (sa < 0 and sb < 0 and sr > 0))",
    "elif aluc == ADDU:",
    "    sum_ = to_uint(a, 32) + to_uint(b, 32)",
    "    expected_carry = (sum_ >> 32) & 1",
    "    expected_r = sum_ & mask32",
    "elif aluc == SUB:",
    "    diff = to_uint(a, 32) - to_uint(b, 32)",
    "    expected_carry = int(to_uint(a, 32) >= to_uint(b, 32))",
    "    expected_r = diff & mask32",
    "    sa = to_sint(a, 32)",
    "    sb = to_sint(b, 32)",
    "    sr = to_sint(expected_r, 32)",
    "    expected_overflow = int((sa > 0 and sb < 0 and sr < 0) or (sa < 0 and sb > 0 and sr > 0))",
    "elif aluc == SUBU:",
    "    diff = to_uint(a, 32) - to_uint(b, 32)",
    "    expected_carry = int(to_uint(a, 32) >= to_uint(b, 32))",
    "    expected_r = diff & mask32",
    "elif aluc == AND:",
    "    expected_r = a & b",
    "elif aluc == OR:",
    "    expected_r = a | b",
    "elif aluc == XOR:",
    "    expected_r = a ^ b",
    "elif aluc == NOR:",
    "    expected_r = (~(a | b)) & mask32",
    "elif aluc == SLT:",
    "    expected_r = int(to_sint(a, 32) < to_sint(b, 32))",
    "    expected_flag = 1",
    "elif aluc == SLTU:",
    "    expected_r = int(to_uint(a, 32) < to_uint(b, 32))",
    "    expected_flag = 1",
    "elif aluc == SLL:",
    "    sh = a & 0x1F",
    "    expected_r = (b << sh) & mask32",
    "elif aluc == SRL:",
    "    sh = a & 0x1F",
    "    expected_r = (b >> sh) & mask32",
    "elif aluc == SRA:",
    "    sh = a & 0x1F",
    "    signed_b = to_sint(b, 32)",
    "    expected_r = to_uint(signed_b >> sh, 32)",
    "elif aluc == SLLV:",
    "    sh = a & 0x1F",
    "    expected_r = (b << sh) & mask32",
    "elif aluc == SRLV:",
    "    sh = a & 0x1F",
    "    expected_r = (b >> sh) & mask32",
    "elif aluc == SRAV:",
    "    sh = a & 0x1F",
    "    signed_b = to_sint(b, 32)",
    "    expected_r = to_uint(signed_b >> sh, 32)",
    "elif aluc == LUI:",
    "    expected_r = (a << 16) & mask32",
    "else:",
    "    expected_r = None  # high\u2011impedance result",
    "# zero and negative flags derived from expected result when defined",
    "if expected_r is not None:",
    "    expected_zero = int((expected_r & mask32) == 0)",
    "    expected_negative = int(to_sint(expected_r, 32) < 0)",
    "else:",
    "    expected_zero = 0",
    "    expected_negative = 0",
    "# carry and overflow may be undefined for non\u2011arithmetic ops",
    "if expected_carry is None:",
    "    assert_true(is_high_impedance(carry) or carry == 0, \"carry undefined but not high\u2011impedance or zero\")",
    "else:",
    "    assert_equal('carry', carry, expected_carry)",
    "if expected_overflow is None:",
    "    assert_true(is_high_impedance(overflow) or overflow == 0, \"overflow undefined but not high\u2011impedance or zero\")",
    "else:",
    "    assert_equal('overflow', overflow, expected_overflow)",
    "# remaining deterministic assertions",
    "assert_equal('r', r, expected_r if expected_r is not None else r)",
    "assert_equal('zero', zero, expected_zero)",
    "assert_equal('negative', negative, expected_negative)",
    "assert_equal('flag', flag, expected_flag)"
  ],
  "helper_calls": [
    "assert_equal",
    "assert_true",
    "to_uint",
