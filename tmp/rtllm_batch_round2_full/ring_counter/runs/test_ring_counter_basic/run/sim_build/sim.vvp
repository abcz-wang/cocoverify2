v0x56040520b1d0_0 .net "reset", 0 0, o0x7f1624bc9078;  0 drivers
v0x56040520b270_0 .var "state", 7 0;
E_0x5604051c4130 .event posedge, v0x56040520b1d0_0, v0x5604051c4690_0;
    .scope S_0x5604051c44a0;
T_0 ;
    %wait E_0x5604051c4130;
