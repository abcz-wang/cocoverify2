    .port_info 1 /INPUT 1 "reset"
    .port_info 2 /OUTPUT 8 "out"
L_0x56040520b3d0 .functor BUFZ 8, v0x56040520b270_0, C4<00000000>, C4<00000000>, C4<00000000>;
o0x7f1624bc9018 .functor BUFZ 1, C4<z>; HiZ drive
v0x5604051c4690_0 .net "clk", 0 0, o0x7f1624bc9018;  0 drivers
v0x56040520b0f0_0 .net "out", 7 0, L_0x56040520b3d0;  1 drivers
