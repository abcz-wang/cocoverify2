S_0x5619d78574d0 .scope module, "verified_JC_counter" "verified_JC_counter" 2 3;
 .timescale -9 -9;
    .port_info 0 /INPUT 1 "clk"
    .port_info 1 /INPUT 1 "rst_n"
    .port_info 2 /OUTPUT 64 "Q"
v0x5619d78576e0_0 .var "Q", 63 0;
