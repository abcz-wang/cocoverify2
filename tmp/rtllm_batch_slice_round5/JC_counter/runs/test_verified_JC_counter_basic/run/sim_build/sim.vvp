E_0x5619d78451b0/1 .event posedge, v0x5619d789e290_0;
E_0x5619d78451b0 .event/or E_0x5619d78451b0/0, E_0x5619d78451b0/1;
    .scope S_0x5619d78574d0;
T_0 ;
